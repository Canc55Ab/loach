{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2016", "DOM"],
    "module": "ESNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*", "rollup.config.ts"],
  "exclude": ["node_modules"]
}
